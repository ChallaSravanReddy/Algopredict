# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ALGOD_TOKEN: Token for Algorand Node (e.g., from PureStake or AlgoNode)
ALGOD_TOKEN=""
# ALGOD_SERVER: URL for Algorand Node
ALGOD_SERVER="https://testnet-api.algonode.cloud"
# ALGOD_PORT: Port for Algorand Node
ALGOD_PORT="443"

# INDEXER_SERVER: URL for Algorand Indexer
INDEXER_SERVER="https://testnet-idx.algonode.cloud"
# INDEXER_PORT: Port for Algorand Indexer
INDEXER_PORT="443"

# ADMIN_MNEMONIC: Mnemonic for the Oracle/Admin account to resolve markets
ADMIN_MNEMONIC=""
